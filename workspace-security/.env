#!/bin/bash
# Security Agent Configuration
# Workspace: ~/.openclaw/workspace-security

# Environment setup
export OPENCLAW_WORKSPACE="/Users/openclaw/.openclaw/workspace-security"

# Model for security agent (use local/offline model)
export SECURITY_MODEL="ollama/llama3:8b"

# Lulu log paths to check
LULU_LOG_PATHS=(
  "/opt/homebrew/var/log/lulu"
  "/var/log/lulu"
  "~/Library/Logs/Lulu"
)

# Alert threshold: number of suspicious connections before notification
SUSPICIOUS_THRESHOLD="${SUSPICIOUS_THRESHOLD:-5}"

# Telegram notification settings
SECURITY_NOTIFY_TO="8462098656"
SECURITY_NOTIFY_CHANNEL="telegram"

# Log file for security audit records
AUDIT_LOG="$OPENCLAW_WORKSPACE/security-audit.log"
INITIAL_MARKER=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
echo "[$INITIAL_MARKER] Security agent initialized. Starting audit..." >> "$AUDIT_LOG"
